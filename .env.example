# =============================================================================
# Wall Scanner — example configuration
# =============================================================================
# Copy this file to `.env` and edit values. The `.env` file is gitignored so
# your bot token / chat id never end up in git.
#
# Boolean values: true / false (also accepts: 1, 0, yes, no, on, off).
# Lists: comma-separated, e.g. QUOTE_ASSETS=USDT,USDC,FDUSD.

# =============================================================================
# Telegram bot
# =============================================================================
# 1. Create a bot: open @BotFather in Telegram → /newbot → follow prompts.
#    Copy the token it gives you.
# 2. Get your numeric chat id: open @userinfobot → send /start → it replies
#    with "Your ID: 12345678". Use that as TG_CHAT_ID for direct messages.
# 3. (Optional) For groups: add your bot as admin, then forward any message
#    from the group to @userinfobot — it shows the group id (negative number).

TG_ENABLED=true
TG_BOT_TOKEN=
TG_CHAT_ID=

# Optional: forum-topic IDs (only if you've turned on Topics in a supergroup).
# Leave blank for plain DMs — every alert lands in one chat.
# TG_TOPIC_LOW=
# TG_TOPIC_MID=
# TG_TOPIC_HIGH=

# Tier thresholds in USD. Walls below TG_TIER_LOW_USD are not sent at all.
TG_TIER_LOW_USD=150000
TG_TIER_MID_USD=500000
TG_TIER_HIGH_USD=2000000

# =============================================================================
# Trading modes — enable / disable independently
# =============================================================================
# Each enabled mode contributes some symbols to the watched universe.
# Disable a mode by setting MODE_<X>_ENABLED=false.

# --- BTC mode (default: BTCUSDT only, $1M wall threshold) ---------------------
MODE_BTC_ENABLED=true
MODE_BTC_SYMBOL=BTCUSDT
MODE_BTC_MIN_WALL_USD=1000000

# --- ETH mode (default: ETHUSDT only, $500k wall threshold) -------------------
MODE_ETH_ENABLED=true
MODE_ETH_SYMBOL=ETHUSDT
MODE_ETH_MIN_WALL_USD=500000

# --- Alts mode (top-N spot pairs by 24h volume, excluding BTC and ETH) --------
MODE_ALTS_ENABLED=true
MODE_ALTS_TOP_N=48
MODE_ALTS_MIN_WALL_USD=150000

# Quote assets accepted for the universe. Comma-separated. Default: USDT.
QUOTE_ASSETS=USDT

# =============================================================================
# Detector — anti-spam filters (shared by all enabled modes)
# =============================================================================
# Maximum distance from mid-price (in %). Walls farther than this are ignored.
MAX_DISTANCE_PCT=3.0

# Minimum distance from mid-price (in %). Filters out the immediate top of book
# where ordinary trader limit orders sit.
MIN_DISTANCE_PCT=0.05

# Wall must persist at least this many seconds before any "appeared" alert
# fires. Main anti-spoofing filter — spoofers don't hold for a full minute.
MIN_LIFETIME_SEC=60

# Wall must be at least this multiple of the median size of nearby levels.
# Default 3.0 → wall is ≥3× the median of the surrounding 20 levels.
RELATIVE_SIZE_MULTIPLIER=3.0
NEIGHBOUR_LEVELS=20

# Walls within this percentage of each other (same side, same symbol) are
# merged into a single zone, so you don't get 5 alerts for one cluster.
ZONE_AGGREGATION_PCT=0.10

# After startup, suppress "appeared" alerts for this many seconds — prevents
# a flood for walls that already existed when the scanner was launched.
COLD_START_GRACE_SEC=120

# When a wall vanishes, the price-cross check uses this window (seconds) to
# decide between EXECUTED and CANCELLED.
EXECUTION_WINDOW_SEC=5

# =============================================================================
# Cooldown
# =============================================================================
# Same wall can't trigger the same kind of event again within this many seconds.
# Default 1800s = 30 min.
COOLDOWN_TTL_SEC=1800

# =============================================================================
# Order book
# =============================================================================
SNAPSHOT_LIMIT=1000
SCAN_INTERVAL_SEC=1.0

# =============================================================================
# Persistence
# =============================================================================
WALLS_LOG_PATH=data/walls.jsonl

# =============================================================================
# Binance endpoints — leave defaults unless you know what you're doing
# =============================================================================
# data-api / data-stream are public CDN endpoints that work in regions where
# api.binance.com / stream.binance.com return HTTP 451.
BINANCE_REST_BASE=https://data-api.binance.vision
BINANCE_WS_BASE=wss://data-stream.binance.vision
BINANCE_WS_RECONNECT_DELAY_SEC=5.0
BINANCE_REST_TIMEOUT_SEC=15.0

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
